# ─── Perplexity / Patent search ───────────────────────────────────────────────
PERPLEXITY_API_KEY=your_perplexity_api_key_here
PERPLEXITY_PATENTS_ENDPOINT=https://api.perplexity.ai/chat/completions
PERPLEXITY_MAX_RESULTS=10
# Set to "mock" to bypass the real API during local development
PATENT_BACKEND=perplexity

# ─── AWS ──────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# ─── S3 buckets ───────────────────────────────────────────────────────────────
MANUSCRIPT_BUCKET=your-manuscript-bucket-name
TASK_BUCKET=your-task-bucket-name

# ─── Lambda / internal service URLs ───────────────────────────────────────────
WORKER_FUNCTION_NAME=your-worker-lambda-function-name
AA_AGENT_URL=https://your-aa-agent-url
IDCA_AGENT_URL=https://your-idca-agent-url
NAA_AGENT_URL=https://your-naa-agent-url

# ─── Frontend ─────────────────────────────────────────────────────────────────
# Copy this to frontend/.env.local and fill in the value
NEXT_PUBLIC_API_URL=https://your-api-gateway-url/prod
